/* ===== 设计令牌 ===== */
page {
  --primary: #07c160;
  --primary-light: #e8f8ee;
  --primary-dark: #06ad56;
  --danger: #fa5151;
  --warning: #ff8f35;
  --text-primary: #1a1a1a;
  --text-secondary: #666666;
  --text-hint: #b2b2b2;
  --border: #f0f0f0;
  --bg: #f7f7f7;
  --bg-card: #ffffff;
  --white: #ffffff;
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);

  font-size: 28rpx;
  color: var(--text-primary);
  background: var(--bg);
  box-sizing: border-box;
}
view, scroll-view, swiper { box-sizing: border-box; }

/* ===== 卡片 / 标签 / 按钮 ===== */
.card { background: var(--bg-card); border-radius: var(--radius-lg); padding: 28rpx; box-shadow: var(--shadow); }

.tag { display: inline-block; padding: 4rpx 16rpx; border-radius: 6rpx; font-size: 22rpx; line-height: 1.6; }
.tag-green  { background: var(--primary-light); color: var(--primary); }
.tag-orange { background: #fef3e2; color: #d4790f; }
.tag-red    { background: #fef0f0; color: var(--danger); }
.tag-blue   { background: #eef4ff; color: #3d7eff; }
.tag-gray   { background: #f5f5f5; color: var(--text-secondary); }

/* 按钮基类：自带 padding/圆角/居中，可单独使用（发布页等） */
.btn { display: flex; align-items: center; justify-content: center; border: none; border-radius: var(--radius-sm); font-size: 28rpx; padding: 18rpx 0; text-align: center; width: 100%; box-sizing: border-box; }
.btn:active { opacity: 0.85; }
.btn-primary { background: var(--primary); color: #fff; }
.btn-outline { background: transparent; color: var(--primary); border: 2rpx solid var(--primary); }
.btn-danger  { background: var(--danger); color: #fff; }
.btn-sm { padding: 10rpx 24rpx; font-size: 24rpx; width: auto; display: inline-flex; border-radius: var(--radius-sm); }

/* ===== Flex / 间距工具类（合并去重） ===== */
.flex-row { display: flex; flex-direction: row; }
.flex-col { display: flex; flex-direction: column; }
.flex-1 { flex: 1; }
.items-center { align-items: center; }
.items-start { align-items: flex-start; }
.justify-between { justify-content: space-between; }

.gap-8  { gap: 8rpx; }
.gap-10 { gap: 10rpx; }
.gap-12 { gap: 12rpx; }
.gap-16 { gap: 16rpx; }
.gap-20 { gap: 20rpx; }
.gap-24 { gap: 24rpx; }
.gap-30 { gap: 30rpx; }

.mt-8  { margin-top: 8rpx; }
.mt-10 { margin-top: 10rpx; }
.mt-12 { margin-top: 12rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-8  { margin-bottom: 8rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-12 { margin-bottom: 12rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.ml-10 { margin-left: 10rpx; }
.ml-12 { margin-left: 12rpx; }
.pt-16 { padding-top: 16rpx; }

/* ===== 文本工具类 ===== */
.text-sm      { font-size: 24rpx; color: var(--text-hint); }
.text-md      { font-size: 26rpx; color: var(--text-secondary); }
.text-lg      { font-size: 30rpx; font-weight: 500; }
.text-bold    { font-weight: 600; }
.text-center  { text-align: center; }
.text-ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.text-line2   { overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.danger       { color: var(--danger); }

/* ===== 表单 ===== */
.form-input { width: 100%; padding: 20rpx 0; font-size: 30rpx; border-bottom: 2rpx solid var(--border); box-sizing: border-box; }
.form-input:focus { border-bottom-color: var(--primary); }
.form-label { font-size: 28rpx; color: var(--text-secondary); margin-bottom: 12rpx; display: block; }

/* ===== 列表 / 菜单 ===== */
.list-item { display: flex; align-items: center; padding: 28rpx 0; border-bottom: 2rpx solid var(--border); }
.list-item:last-child { border-bottom: none; }
.menu-item { display: flex; align-items: center; gap: 20rpx; padding: 24rpx 0; border-bottom: 2rpx solid var(--border); }
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 32rpx; width: 40rpx; text-align: center; }
.menu-text { flex: 1; font-size: 28rpx; }
.menu-arrow { font-size: 28rpx; color: var(--text-hint); }
.menu-badge { background: var(--danger); color: #fff; font-size: 22rpx; padding: 2rpx 14rpx; border-radius: 20rpx; min-width: 28rpx; text-align: center; }
.section-title { font-size: 28rpx; font-weight: 600; color: var(--text-primary); padding: 16rpx 0; }

/* ===== 状态组件 ===== */
.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 120rpx 0 80rpx; gap: 16rpx; color: var(--text-hint); font-size: 28rpx; }
.empty-icon { font-size: 80rpx; opacity: 0.3; }
.empty-text { font-size: 28rpx; color: var(--text-hint); }
.loading-more { text-align: center; padding: 30rpx; color: var(--text-hint); font-size: 24rpx; }
.overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 999; }
.safe-bottom { padding-bottom: env(safe-area-inset-bottom); }
