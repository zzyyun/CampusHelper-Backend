.detail-info{background:var(--bg);border-radius:8rpx;padding:16rpx 20rpx}
.info-row{display:flex;gap:12rpx;font-size:26rpx;color:var(--text-secondary);margin-bottom:8rpx}
.info-label{color:var(--text-hint);width:120rpx;flex-shrink:0}
.reward{color:var(--danger);font-weight:500}
.claim-form{position:fixed;bottom:0;left:0;right:0;background:var(--white);border-radius:24rpx 24rpx 0 0;padding:40rpx 32rpx;z-index:1000;padding-bottom:env(safe-area-inset-bottom)}
.claim-title{font-size:34rpx;font-weight:600;margin-bottom:24rpx}
.claim-textarea{width:100%;min-height:120rpx;font-size:28rpx;border:2rpx solid var(--border);border-radius:8rpx;padding:16rpx}
