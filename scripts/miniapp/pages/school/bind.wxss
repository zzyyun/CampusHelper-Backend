.school-page { min-height: 100vh; background: var(--white); }
.school-header { padding: 60rpx 32rpx 30rpx; }
.school-title { font-size: 40rpx; font-weight: 600; color: var(--text-primary); margin-bottom: 12rpx; }
.school-desc { font-size: 26rpx; color: var(--text-hint); margin-bottom: 30rpx; }
.school-search { background: var(--bg); border-radius: 12rpx; padding: 20rpx 24rpx; font-size: 28rpx; }
.school-list { height: calc(100vh - 280rpx); padding: 0 32rpx; }
.school-item { display: flex; justify-content: space-between; align-items: center; padding: 28rpx 0; border-bottom: 2rpx solid var(--border); }
.school-name { font-size: 30rpx; font-weight: 500; }
.school-province { font-size: 26rpx; color: var(--text-hint); }
