.user-list{height:calc(100vh - 120rpx);padding:0 24rpx}
.user-item{margin-bottom:16rpx}
.ml-10{margin-left:10rpx}
.search-bar{padding:20rpx 24rpx;gap:16rpx}
.search-input{background:var(--bg);border-radius:40rpx;padding:16rpx 24rpx;font-size:28rpx}
.search-btn{font-size:28rpx;color:var(--primary);padding:16rpx}
.ban-form{position:fixed;bottom:0;left:0;right:0;background:var(--white);border-radius:24rpx 24rpx 0 0;padding:40rpx 32rpx;z-index:1000;padding-bottom:env(safe-area-inset-bottom)}
.ban-title{font-size:34rpx;font-weight:600;margin-bottom:24rpx}
.ban-textarea{width:100%;min-height:120rpx;font-size:28rpx;border:2rpx solid var(--border);border-radius:8rpx;padding:16rpx}
