<wxs src="../../utils/format.wxs" module="fmt"/>
<view class="profile-page">
  <view class="profile-header">
    <view class="profile-bg"></view>
    <view class="profile-info flex-col items-center">
      <view class="profile-avatar">{{avatarText}}</view>
      <text class="profile-name">{{userInfo?userInfo.nickname:'用户'}}</text>
      <text wx:if="{{schoolName}}" class="profile-school">{{schoolName}}</text>
      <text wx:else class="profile-school hint">尚未绑定学校</text>
    </view>
  </view>
  <view class="profile-section card mt-20">
    <view class="menu-item" bindtap="onNavigate" data-url="/pages/search/search">
      <text class="menu-icon">🔍</text><text class="menu-text">搜索</text><text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onNavigate" data-url="/pages/notifications/notifications">
      <text class="menu-icon">🔔</text><text class="menu-text">消息通知</text>
      <view wx:if="{{unreadCount>0}}" class="menu-badge">{{unreadCount>99?'99+':unreadCount}}</view>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onNavigate" data-url="/pages/post/create?type=2">
      <text class="menu-icon">🥥</text><text class="menu-text">发布失物招领</text><text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onNavigate" data-url="/pages/post/create?type=3">
      <text class="menu-icon">📦</text><text class="menu-text">发布二手交易</text><text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onNavigate" data-url="/pages/task/create">
      <text class="menu-icon">📋</text><text class="menu-text">发布任务</text><text class="menu-arrow">></text>
    </view>
  </view>
  <view wx:if="{{isAdmin}}" class="profile-section card mt-20">
    <view class="menu-item" bindtap="onNavigate" data-url="/pages/admin/index">
      <text class="menu-icon">⚙️</text><text class="menu-text">管理后台</text><text class="menu-arrow">></text>
    </view>
  </view>
  <view class="profile-logout"><view class="btn btn-outline" bindtap="onLogout" style="color:var(--danger);border-color:var(--danger);border-radius:50rpx">退出登录</view></view>
</view>
