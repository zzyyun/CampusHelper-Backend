.home-page { min-height: 100vh; padding-bottom: 140rpx; }
.home-header { padding: 16rpx 24rpx 12rpx; background: var(--bg-card); position: sticky; top: 0; z-index: 10; }
.school-name { font-size: 34rpx; font-weight: 700; color: var(--text-primary); }
.search-bar { display: flex; align-items: center; gap: 12rpx; background: var(--bg); border-radius: 40rpx; padding: 16rpx 24rpx; margin-top: 12rpx; font-size: 26rpx; color: var(--text-hint); }
.search-text { font-size: 26rpx; color: var(--text-hint); flex: 1; }

.tab-bar { display: flex; white-space: nowrap; background: var(--bg-card); padding: 0 24rpx; border-bottom: 2rpx solid var(--border); }
.tab-item { display: inline-flex; flex-direction: column; align-items: center; padding: 18rpx 20rpx; font-size: 26rpx; color: var(--text-secondary); position: relative; margin-right: 8rpx; }
.tab-item.active { color: var(--primary); font-weight: 600; }
.tab-line { height: 4rpx; background: var(--primary); border-radius: 2rpx; width: 40rpx; margin-top: 10rpx; }

.feed-list { padding: 16rpx 20rpx; }
.feed-card { margin-bottom: 16rpx; border-radius: var(--radius-lg); }
.feed-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; background: var(--primary-light); color: var(--primary); display: flex; align-items: center; justify-content: center; font-size: 26rpx; font-weight: 600; flex-shrink: 0; }
.author-name { font-size: 26rpx; font-weight: 500; color: var(--text-primary); }
.feed-title { font-size: 30rpx; font-weight: 600; color: var(--text-primary); line-height: 1.4; }
.feed-content { font-size: 26rpx; color: var(--text-secondary); line-height: 1.6; }
.feed-images { display: flex; gap: 8rpx; }
.feed-thumb { width: 200rpx; height: 200rpx; border-radius: var(--radius-sm); background: var(--bg); }
.feed-actions { font-size: 24rpx; color: var(--text-hint); }

.fab { position: fixed; bottom: 140rpx; right: 32rpx; width: 96rpx; height: 96rpx; border-radius: 50%; background: var(--primary); color: #fff; display: flex; align-items: center; justify-content: center; box-shadow: 0 4rpx 20rpx rgba(7,193,96,0.4); z-index: 100; }
.fab-icon { font-size: 48rpx; font-weight: 300; line-height: 1; }
