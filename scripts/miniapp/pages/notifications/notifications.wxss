.notify-actions{padding:20rpx 32rpx;background:var(--white);border-bottom:2rpx solid var(--border);display:flex;justify-content:space-between;align-items:center;font-size:26rpx}
.notify-action{color:var(--primary)}
.notify-item{padding:24rpx 32rpx;background:var(--white);border-bottom:2rpx solid var(--border)}
.notify-item.unread{background:#f0fdf4}
.notify-dot{width:12rpx;height:12rpx;border-radius:50%;background:var(--text-hint);display:inline-block}
.notify-dot.active{background:var(--danger)}
.notify-title{font-size:28rpx;color:var(--text-primary);margin-top:8rpx}
.notify-content{font-size:26rpx;color:var(--text-secondary);margin-top:4rpx}
.notify-delete{font-size:24rpx;color:var(--danger)}
