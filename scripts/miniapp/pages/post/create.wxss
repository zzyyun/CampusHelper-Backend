.create-page{min-height:100vh;background:var(--white)}
.create-scroll{padding-bottom:60rpx}
.create-section{padding:24rpx 32rpx;border-bottom:2rpx solid var(--border)}
.type-selector{gap:16rpx}
.type-option{flex:1;text-align:center;padding:16rpx 0;border-radius:12rpx;border:2rpx solid var(--border);font-size:28rpx;color:var(--text-secondary)}
.type-option.active{border-color:var(--primary);color:var(--primary);background:var(--primary-light)}
.form-textarea{width:100%;min-height:200rpx;font-size:28rpx;border:none;background:var(--bg);border-radius:8rpx;padding:16rpx;box-sizing:border-box}
.image-grid{flex-wrap:wrap}
.image-preview{width:180rpx;height:180rpx;border-radius:8rpx;overflow:hidden;position:relative}
.image-preview image{width:100%;height:100%}
.image-remove{position:absolute;top:-8rpx;right:-8rpx;width:36rpx;height:36rpx;border-radius:50%;background:rgba(0,0,0,.6);color:white;display:flex;align-items:center;justify-content:center;font-size:24rpx}
.image-add{width:180rpx;height:180rpx;border-radius:8rpx;border:2rpx dashed var(--border);display:flex;align-items:center;justify-content:center}
.add-icon{font-size:48rpx;color:var(--text-hint)}
.extra-fields{background:var(--primary-light)}
.picker-value{font-size:28rpx;padding:20rpx 0;border-bottom:2rpx solid var(--border)}
.create-submit{padding:60rpx 32rpx}
